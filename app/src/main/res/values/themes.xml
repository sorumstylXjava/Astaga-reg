<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.JavaPro" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.App.Transparent" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
    </style>

    <style name="Theme.App.FullScreen" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>